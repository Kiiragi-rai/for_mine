<% if current_user.partner.present? %>

<div class="container py-4" data-controller="gift-loading">





      <%= form_with url: gift_suggestions_path,
        data: { turbo: false , action: "submit->gift-loading#submit"} do |form| %>
    <div class="text-center py-4">
        <%= form.submit "プレゼントを考える",
            class: "btn btn-primary",
            data: { gift_loading_target: "submitButton"} %>

      <% end %>

      <div data-gift-loading-target="loadingIndicator"
           style="display:none"
           class="mt-3">

        <p>あなたの気持ちに合うプレゼントを考えています…</p>

      </div>

    </div>

  <% if @contents %>

    <div class="card mt-4">
      <div class="card-body">

        <h3 class="mb-3">こんなプレゼントはどうかな？</h3>

        <ul>
          <% @contents['presentSuggestions'].each do |presentSuggestion| %>
            <li>
              <strong><%= presentSuggestion['name'] %></strong>
              - <%= presentSuggestion['reason'] %>
            </li>
          <% end %>
        </ul>

      </div>
    </div>

  <% end %>

</div>

<% else %>

<div class="container py-4 text-center">

  <p class="mb-3">まだパートナーの情報がありません😊</p>
  <p class="text-muted small mb-4">
    大切な人のことを教えてくれると、ぴったりなプレゼントを考えられるよ
  </p>

  <%= link_to "パートナーを登録する",
      new_partner_path,
      class:"btn btn-primary" %>
</div>
<% end %>