<%= search_form_for q, url: admin_gift_suggestions_path, method: :get do |f| %>

<div class="row g-3 mb-3">

  <div class="col-md-3">
    <%= f.label :id_eq, "ID" %>
    <%= f.search_field :id_eq, class:"form-control" %>
  </div>

  <div class="col-md-3">
    <%= f.label :user_id_eq, "User ID" %>
    <%= f.search_field :user_id_eq, class:"form-control" %>
  </div>

  <div class="col-md-3">
    <%= f.label :status_eq, "Status" %>
    <%= f.select :status_eq,
        GiftSuggestion.statuses.keys,
        { include_blank: true },
        class:"form-control" %>
  </div>

  <div class="col-md-3 d-flex align-items-end">

    <%= f.submit "検索", class:"btn btn-primary me-2" %>

    <%= link_to "リセット",
        admin_gift_suggestions_path,
        class:"btn btn-secondary" %>

  </div>

</div>

<% end %>