<div class="container">

    <h1 class="mb-4">Users</h1>
    
    <%= render "search", q: @q %>
    
    <table class="table table-striped table-hover">
    
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Date</th>
        </tr>
      </thead>
    
      <tbody>
    
        <% @users.each do |user| %>
    
        <tr>
          <td><%= user.id %></td>
          <td><%= user.name %></td>
          <td><%= l user.created_at, format: :short %></td>
        </tr>
    
        <% end %>
    
      </tbody>
    
    </table>
    
    <div class="d-flex justify-content-center mt-4">
      <%= paginate @users %>
    </div>
    
    </div>