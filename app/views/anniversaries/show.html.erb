<div class="container pt-5">

  <div class="row justify-content-center">
    <div class="col-lg-8">

      <h1 class="mb-4">記念日詳細</h1>

      <article class="card shadow-sm">
        <div class="card-body">

          <div class="row mb-3">

            <div class="col-md-6">
              <h5 class="card-title">タイトル</h5>
              <p class="card-text"><%= @anniversary.title %></p>
            </div>

            <div class="col-md-6">
              <h5 class="card-title">日付</h5>
              <p class="card-text"><%= @anniversary.anniversary_date %></p>
            </div>

          </div>

          <div class="d-flex gap-2">
            <%= link_to "編集",
                edit_anniversary_path(@anniversary),
                class: "btn btn-outline-primary" %>

            <%= link_to "削除",
                anniversary_path(@anniversary),
                data: { turbo_method: :delete },
                class: "btn btn-outline-danger" %>
          </div>

        </div>
      </article>

      <div class="mt-4">
        <%= link_to "一覧へ",
            anniversaries_path,
            class: "btn btn-outline-secondary" %>
      </div>

    </div>
  </div>

</div>