<%= search_form_for q,
    url: admin_notification_managements_path,
    method: :get do |f| %>

<div class="row g-3 mb-3">

  <div class="col-md-4">

    <%= f.label :status_eq, "status" %>

    <%= f.select :status_eq,
        NotificationManagement.statuses.keys,
        { include_blank: true },
        class:"form-control" %>

  </div>

  <div class="col-md-4 d-flex align-items-end">

    <%= f.submit "検索", class:"btn btn-primary me-2" %>

    <%= link_to "リセット",
        admin_notification_managements_path,
        class:"btn btn-secondary" %>

  </div>

</div>

<% end %>