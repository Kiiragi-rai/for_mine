<div class="container mb-4">

  <%= search_form_for q, url: admin_users_path, method: :get do |f| %>
  
  <div class="row g-3 align-items-end">
  
    <div class="col-md-4">
      <%= f.label :id_eq, "id", class:"form-label" %>
      <%= f.search_field :id_eq, class:"form-control" %>
    </div>
  
    <div class="col-md-4">
      <%= f.submit "検索", class:"btn btn-primary me-2" %>
      <%= link_to "リセット", admin_users_path, class:"btn btn-secondary" %>
    </div>
  
  </div>
  
  <% end %>
  
  </div>