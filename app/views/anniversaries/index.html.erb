<div class="container py-4">



<%= render "search", q:@q %>

<% if @anniversaries.present? %>

<div class="row g-3">

  <% @anniversaries.each do |anniversary| %>

    <div class="col-12 col-md-6 col-lg-4">

      <div class="card h-100 shadow-sm">

        <div class="card-body">

          <h5 class="card-title">
            <%= anniversary.title %>
          </h5>

          <p class="card-text">
            記念日：<%= anniversary.anniversary_date %>
          </p>

          <p class="card-text">
            通知日：<%= anniversary.notification_setting&.start_on %>
          </p>

          <p class="card-text">
            通知設定：
            <%= anniversary.notification_setting&.is_enabled ? "ON" : "OFF" %>
          </p>

          <div class="text-success">
            <%= anniversary.anniversary_calculate %>
          </div>

        </div>

        <div class="card-footer bg-white">

          <%= link_to "詳細",
            anniversary_path(anniversary),
            class:"btn btn-sm btn-outline-primary" %>

          <%= link_to "編集",
            edit_anniversary_path(anniversary),
            class:"btn btn-sm btn-outline-secondary" %>

          <%= link_to "削除",
            anniversary_path(anniversary),
            data: { turbo_method: :delete },
            class:"btn btn-sm btn-outline-danger" %>

        </div>

      </div>

    </div>

  <% end %>

</div>


<div class="mt-4">
  <%= link_to "記念日追加",
    new_anniversary_path,
    class:"btn btn-primary" %>
</div>


<% else %>

<p>記念日がありません</p>

<%= link_to "記念日作成",
  new_anniversary_path,
  class:"btn btn-primary" %>

<% end %>


<!-- LINE -->
<div class="mt-5">
<p class="text-muted mb-3">
  ※通知を受け取るには公式LINE登録が必要です
</p>
<a href="https://lin.ee/XNdU8tj">
  <img src="https://scdn.line-apps.com/n/line_add_friends/btn/ja.png"
       alt="友だち追加"
       height="36">
</a>
</div>


<!-- pagination -->
<div class="d-flex justify-content-center mt-4">
<%= paginate @anniversaries %>
</div>


<div class="mt-3">
<%= link_to "カレンダーへ", calendar_anniversaries_path, class:"btn btn-outline-dark" %>
</div>

