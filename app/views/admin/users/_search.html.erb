<%= search_form_for q, url: admin_users_path, method: :get do |f| %>

<div class="row g-3 mb-3">

  <div class="col-md-4">
    <%= f.label :name_cont, "名前" %>
    <%= f.search_field :name_cont, class: "form-control" %>
  </div>

  <div class="col-md-3">
    <%= f.label :id_eq, "ID" %>
    <%= f.search_field :id_eq, class: "form-control" %>
  </div>

  <div class="col-md-5 d-flex align-items-end">

    <%= f.submit "検索", class: "btn btn-primary me-2" %>

    <%= link_to "リセット",
        admin_users_path,
        class: "btn btn-secondary" %>

  </div>

</div>

<% end %>