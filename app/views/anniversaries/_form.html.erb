<div class="card shadow-sm">
  <div class="card-body">

<% form_with_options = form.anniversary.persisted? ?
  { url: anniversary_path(form.anniversary), method: :patch } :
  { url: anniversaries_path, method: :post} %>

<%= form_with model: form ,**form_with_options do |f| %>

  <%= render 'shared/error_messages', object: f.object %>

  <div class="mb-3">
    <%= f.label :title, "タイトル", class:"form-label" %>
    <%= f.text_field :title, class:"form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :anniversary_date, "記念日", class:"form-label" %>
    <%= f.date_field :anniversary_date, class:"form-control" %>
  </div>

  <div class="mb-3">
    <label class="form-label">通知設定</label>

    <div class="form-check">
      <%= f.radio_button :is_enabled, true, checked: @form.is_enabled, class:"form-check-input" %>
      <%= f.label :is_enabled, "ON", class:"form-check-label" %>
    </div>

    <div class="form-check">
      <%= f.radio_button :is_enabled, false, checked: !@form.is_enabled, class:"form-check-input" %>
      <%= f.label :is_enabled, "OFF", class:"form-check-label" %>
    </div>
  </div>
  <div class="mb-3">
    <%= f.label :start_on, "通知開始日", class:"form-label" %>
    <%= f.date_field :start_on, class:"form-control" %>
  </div>
  
  <div class="mb-3">
    <%= f.label :notification_hour, "通知時間", class:"form-label" %>

    <%= f.select :notification_hour,
      (0..23).map { |h| ["%02d:00" % h,h] },
      { include_blank: true },
      class:"form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :frequency_days, "通知頻度", class:"form-label" %>

    <%= f.select :frequency_days,
      options_for_select(NotificationSetting.frequency_days.map {|k,v| [k,v]}, f.object.frequency_days),
      {},
      class:"form-select" %>
  </div>




  <div class="text-end">
    <%= f.submit submit_label, class:"btn btn-primary" %>
  </div>

<% end %>

  </div>
</div>